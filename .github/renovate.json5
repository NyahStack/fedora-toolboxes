{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommits",
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/build_files/versions\\.env$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s*\\nDISTROBOX_REF=(?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "automerge": true,
      "matchUpdateTypes": ["pin", "pinDigest"]
    },
    {
      // Chunkah's digest is intentionally tracked in image-versions.yaml and
      // passed through CHUNKAH_IMAGE_DIGEST. Pinning the Containerfile FROM line
      // creates an invalid duplicate digest expression.
      "enabled": false,
      "matchManagers": ["dockerfile"],
      "matchFileNames": ["Containerfile"],
      "matchPackageNames": ["quay.io/coreos/chunkah"],
      "matchUpdateTypes": ["pin", "pinDigest"]
    },
    {
      "enabled": false,
      "matchUpdateTypes": ["digest", "pinDigest", "pin"],
      "matchDepTypes": ["container"],
      "matchFileNames": [".github/workflows/**.yaml", ".github/workflows/**.yml", ".devcontainer/Containerfile"]
    },
    {
      "matchPackageNames": [
        "registry.fedoraproject.org/*",
        "quay.io/coreos/chunkah",
      ],
      "groupName": "images",
      "matchUpdateTypes": [
        "digest"
      ],
      "automerge": true
    },
    {
      "matchPackageNames": [
        "registry.fedoraproject.org/*",
        "quay.io/coreos/chunkah",
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "quay.io/fedora/fedora"
      ],
      "matchFileNames": [
        ".devcontainer/Containerfile"
      ],
      "enabled": false
    },
    {
      "matchFileNames": [
        "build_files/versions.env"
      ],
      "matchPackageNames": [
        "89luca89/distrobox"
      ],
      "groupName": "distrobox",
      "automerge": true
    }
  ]
}
